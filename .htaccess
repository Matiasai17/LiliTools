# SPA rewrite para Hostinger (Apache).
# La app usa BrowserRouter con rutas limpias (/tools/:id). Sin esta regla,
# recargar o entrar directo a una ruta profunda devolvería 404.
# Toda petición que no sea un archivo o carpeta real se sirve con index.html;
# React Router resuelve la ruta del lado del cliente.

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # No reescribir archivos ni directorios existentes (assets, etc.)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Todo lo demás → index.html
  RewriteRule ^ index.html [L]
</IfModule>

# Cache largo para assets con hash (Vite genera nombres con hash).
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 month"
</IfModule>
